# Exemplo de secrets para o Streamlit Cloud / Streamlit local
# Copie este arquivo para `.streamlit/secrets.toml` e preencha os valores reais.
# NUNCA comite o secrets.toml real no GitHub.

# ── Banco de dados ─────────────────────────────────────────────
# Para produção no Streamlit Cloud use PostgreSQL (ex: Supabase).
# A URL deve começar com postgresql://
# DATABASE_URL = "postgresql://user:password@host:port/database"

# Para desenvolvimento local com SQLite, defina o caminho do arquivo.
# No Streamlit Cloud, bancos SQLite em /tmp são perdidos após reinícios.
DB_PATH = "hocta_conecta.db"

# ── Segurança ──────────────────────────────────────────────────
# Chave para criptografar senhas de e-mail IMAP.
# Gere uma chave com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_FERNET_KEY = "sua-chave-fernet-aqui"

# Chave para validar webhooks do WhatsApp (WPPConnect).
WEBHOOK_SECRET = "sua-chave-webhook-aqui"

# ── WhatsApp / WPPConnect ──────────────────────────────────────
# URL do servidor WPPConnect (deixe vazio para desabilitar no Cloud).
WPP_URL = "http://localhost:21465"
WPP_TOKEN = "seu-token-aqui"
WPP_SESSION = "hocta"

# Executivo padrão para mensagens não identificadas (ID numérico).
EXEC_DEFAULT_ID = "1"
